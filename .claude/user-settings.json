{
  "theme": "dark",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.local/bin/ensure-agent-research-dir\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.local/bin/ensure-agent-research-dir\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.local/bin/ensure-agent-research-dir\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.local/bin/ensure-agent-research-dir\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
