# --- identity ---
[user]
    name = Andy Galkin
    email = andy.galkin+github@gmail.com
[github]
    user = galkk

# --- aliases ---
[alias]
    dt = -c diff.external=difft diff              # AST-aware structural diff
    dv = "!nvim -c 'DiffviewOpen'"                # interactive diff with fold/file tree
    wd = diff --color-words --word-diff-regex='\\w+'
    dc = "!code --new-window --wait ."             # VS Code SCM view
    cleanup-merged = "!f(){ cur=$(git symbolic-ref --quiet --short HEAD) || exit 0; git for-each-ref --format='%(refname:short)' refs/heads --merged HEAD | awk -v cur=\"$cur\" '$0!=cur && $0!=\"main\" && $0!=\"master\"' | xargs -n1 -P ${1:-8} -I{} sh -c 'git branch -d -v \"$1\" || true' _ {}; true; }; f"
    cleanup-gone = "!git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' refs/heads | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -D 2>/dev/null; true"
    cleanup = "!git cleanup-merged && git cleanup-gone"

# --- delta pager ---
[core]
    editor = vim
    whitespace = -trailing-space
    pager = delta
    untrackedCache = true
    fsmonitor = true
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true              # n/N to jump between diff sections
    line-numbers = true
    hyperlinks = true            # clickable file paths in iTerm2
    hunk-header-decoration-style = none
    word-diff-regex = "\\w+"

# --- diff ---
[diff]
    algorithm = histogram        # cleaner diffs than patience, handles repeated lines
    colorMoved = default
    mnemonicPrefix = true
    tool = vscode
[difftool]
    prompt = false
[difftool "vscode"]
    cmd = code --new-window --wait --diff $LOCAL $REMOTE

# --- merge / rebase ---
[merge]
    conflictStyle = zdiff3       # show common ancestor + auto-resolve unambiguous parts
[mergetool]
    keepBackup = false
    writeToTemp = true
    prompt = false
[rebase]
    instructionFormat = [%ai] %s
    rebaseMerges = true
    autoSquash = true
    updateRefs = true            # auto-move stacked branch pointers on rebase
    autoStash = true             # stash/pop dirty worktree around rebase
    missingCommitsCheck = warn   # warn if commits dropped during interactive rebase
[rerere]
    enabled = true
    autoupdate = true

# --- history / display ---
[log]
    abbrevCommit = true
    follow = true
[format]
    pretty = "format:%C(auto)%h %<(100,trunc)%s %C(blue)%<(15,trunc)%an %C(auto)(%ar) %C(auto) %d"
[branch]
    sort = -committerdate        # most recently used branches first
[tag]
    sort = version:refname       # v1.2, v1.10 sorted numerically
[commit]
    verbose = true               # show diff in commit message editor
[status]
    short = true

# --- network ---
[pull]
    ff = only
[push]
    autoSetupRemote = true
    followTags = true            # auto-push annotated tags
[fetch]
    prune = true
    pruneTags = true             # clean stale remote tags
    recurseSubmodules = on-demand
    writeCommitGraph = true      # speeds up log/blame/merge-base
    unpackLimit = 1

[index]
    version = 4
    skipHash = true

[pack]
    usePathWalk = true

# --- integrity ---
[transfer]
    fsckObjects = true
[column]
    ui = auto                    # branch/tag lists in columns

# --- misc ---
[help]
    autocorrect = prompt          # ask before executing corrected command
[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
[include]
    path = ~/.work.gitconfig
[maintenance]
	repo = /Users/andrii.galkin/projects/1brc
	repo = /Users/andrii.galkin/projects/affirm-ansible
	repo = /Users/andrii.galkin/projects/affirm-builders
	repo = /Users/andrii.galkin/projects/afrm-rulez
	repo = /Users/andrii.galkin/projects/all-the-things
	repo = /Users/andrii.galkin/projects/app-k8s-components
	repo = /Users/andrii.galkin/projects/architecture
	repo = /Users/andrii.galkin/projects/cosmops
	repo = /Users/andrii.galkin/projects/db-utils
	repo = /Users/andrii.galkin/projects/dbops
	repo = /Users/andrii.galkin/projects/dotfiles
	repo = /Users/andrii.galkin/projects/lib-build-tools-jvm
	repo = /Users/andrii.galkin/projects/salt
	repo = /Users/andrii.galkin/projects/table-carveout-spec
	repo = /Users/andrii.galkin/projects/terraffirm
